# Fred backend production env
# Copy to your hosting provider / Railway variables.
# Do not commit a filled .env file.

FRED_NETWORK=base-mainnet
FRED_CHAIN_ID=8453

# Use 365 for a tiny mainnet canary, then switch to 31536000 for real launch.
FRED_LOCK_SECONDS=365

FRED_CONFIRMATIONS=4
FRED_STATE_PATH=/data/mainnet-state.json

# REQUIRED: use a stable paid Base mainnet RPC, not a flaky public RPC.
# Examples: Alchemy, QuickNode, Infura, Ankr.
FRED_RPC_URL=

# REQUIRED SECRET: 32-byte hex seed used to derive unique deposit addresses.
FRED_MASTER_SEED_HEX=

# REQUIRED SECRET: hot treasury private key used for gas, sweeps, claims, withdrawals.
FRED_TREASURY_PRIVATE_KEY=

# REQUIRED SECRET for admin-only recovery endpoints.
# Needed for /v1/admin/positions/:id/export-key and /alerts.
FRED_ADMIN_TOKEN=

# Base native USDC, verified mainnet address.
FRED_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Optional: configure additional accepted stables once contract addresses are verified.
# Tokens with matching decimals can be accepted as principal; others become admin alerts.
FRED_USDT_ADDRESS=0x0000000000000000000000000000000000000000
FRED_DAI_ADDRESS=0x0000000000000000000000000000000000000000
FRED_OUSD_ADDRESS=0x0000000000000000000000000000000000000000

# Future wrong-chain watchers (not active unless implemented/deployed with a chain client).
# Same derived deposit address exists on EVM chains, but each chain needs its own RPC + token map.
FRED_POLYGON_RPC_URL=
FRED_POLYGON_USDT_ADDRESS=
FRED_POLYGON_USDC_ADDRESS=
