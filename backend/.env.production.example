# Fred backend production env
# Copy to your hosting provider / Railway variables.
# Do not commit a filled .env file.

FRED_NETWORK=base-mainnet
FRED_CHAIN_ID=8453

# Use 365 for a tiny mainnet canary, then switch to 31536000 for real launch.
FRED_LOCK_SECONDS=365

FRED_CONFIRMATIONS=4
FRED_STATE_PATH=/data/mainnet-state.json

# REQUIRED: use a stable paid Base mainnet RPC, not a flaky public RPC.
# Examples: Alchemy, QuickNode, Infura, Ankr.
FRED_RPC_URL=

# REQUIRED SECRET: 32-byte hex seed used to derive unique deposit addresses.
FRED_MASTER_SEED_HEX=

# REQUIRED SECRET: hot treasury private key used for gas, sweeps, claims, withdrawals.
FRED_TREASURY_PRIVATE_KEY=

# Base native USDC, verified mainnet address.
FRED_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
